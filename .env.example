# Discord bot credentials — https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: restrict slash commands to a single guild during dev (instant updates instead of 1h)
DISCORD_GUILD_ID=

# Twitch API — https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# RSSHub instance for TikTok (deploy your own on Railway, see README)
# Example: https://rsshub-production-xxxx.up.railway.app
RSSHUB_URL=https://rsshub.app

# SQLite path. On Railway, mount a Volume on /data and set this to /data/notify.db
DATABASE_PATH=./data/notify.db

# Poll intervals (cron expressions)
YOUTUBE_CRON=*/5 * * * *
TWITCH_CRON=*/2 * * * *
TIKTOK_CRON=*/10 * * * *
